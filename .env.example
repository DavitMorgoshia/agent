# ──────────────────────────────────────────
# LLM Provider — pick one
# ──────────────────────────────────────────

# Which LLM provider to use: "anthropic" (default) or "gemini"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini — https://aistudio.google.com/app/apikey
# Required only when LLM_PROVIDER=gemini
GEMINI_API_KEY=AQ.Ab8RN6KoKINGvaMImzxCPWQYlEdg8kYNl_1fkGLS07_-qadhow

# ──────────────────────────────────────────
# Optional — Notifications
# ──────────────────────────────────────────

# Slack incoming webhook URL for notifications
# Create at: https://api.slack.com/messaging/webhooks
# If not set, notifications are logged to console only
SLACK_WEBHOOK_URL=

# ──────────────────────────────────────────
# Optional — Email Provider
# ──────────────────────────────────────────

# Mailgun
# Sign up at https://mailgun.com (free tier available)
# Set up inbound routing to forward to https://your-host/webhook/mailgun
MAILGUN_SIGNING_KEY=

# ──────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────

# Host and port for the server (defaults shown)
HOST=0.0.0.0
PORT=8000
